{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "waste_item.schema.json",
  "title": "Waste Item",
  "type": "object",
  "required": ["id", "title", "added_at", "added_by", "source_type", "license_status", "summary", "allowed_use"],
  "properties": {
    "id": { "type": "string", "pattern": "^W[0-9]{6}$" },
    "title": { "type": "string", "minLength": 3 },
    "added_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "added_by": { "type": "string" },
    "source_type": {
      "type": "string",
      "enum": ["text", "code", "document", "dataset", "idea", "example", "unknown"]
    },
    "license_status": {
      "type": "string",
      "enum": ["unknown", "public-domain", "internal-example", "requires-attribution", "restricted"]
    },
    "hazard_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["untrusted", "needs-review", "prompt-injection-risk", "malware-risk", "privacy", "example", "safe"]
      }
    },
    "summary": { "type": "string", "minLength": 10 },
    "allowed_use": {
      "type": "string",
      "enum": ["analysis-only", "template-only", "full-use", "quarantined"]
    },
    "notes": { "type": "string" }
  }
}
