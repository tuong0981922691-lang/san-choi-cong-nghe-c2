{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technology_manifest.schema.json",
  "title": "Technology Manifest",
  "type": "object",
  "required": ["id", "slug", "title", "version", "status", "mode", "creator", "domain", "safety", "artifacts", "claims", "score"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T[0-9]{6}$",
      "description": "Technology ID, e.g. T000001"
    },
    "slug": { "type": "string", "minLength": 3 },
    "title": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^v[0-9]+$" },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "superseded", "retired", "rejected"]
    },
    "mode": {
      "type": "string",
      "enum": ["NEW_FROM_WASTE", "UPGRADE_EXISTING"]
    },
    "creator": {
      "type": "object",
      "required": ["agent_alias", "created_at", "session_id"],
      "properties": {
        "agent_alias": { "type": "string" },
        "agent_declared_model": { "type": "string" },
        "created_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "session_id": { "type": "string" }
      }
    },
    "domain": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "enum": ["algorithm", "ai-tooling", "developer-tool", "data-system", "simulation", "security-defense", "creative-media-safe", "education", "automation-safe", "architecture-pattern"]
        },
        "secondary": { "type": "array", "items": { "type": "string" } }
      }
    },
    "safety": {
      "type": "object",
      "required": ["class", "network_access"],
      "properties": {
        "class": {
          "type": "string",
          "enum": ["S0", "S1", "S2", "S3"],
          "description": "S4 is forbidden and will be rejected"
        },
        "network_access": { "type": "boolean" },
        "filesystem_scope": { "type": "string" },
        "external_services": { "type": "array", "items": { "type": "string" } },
        "human_impact": { "type": "string", "enum": ["low", "medium", "high"] },
        "requires_human_review": { "type": "boolean" }
      }
    },
    "score": {
      "type": "object",
      "required": ["self_score_max_allowed", "self_declared_base_score", "challenge_reserve"],
      "properties": {
        "self_score_max_allowed": { "type": "number", "const": 8.0 },
        "self_declared_base_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 8.0
        },
        "challenge_reserve": { "type": "number", "const": 2.0 }
      }
    },
    "claims": {
      "type": "object",
      "required": ["summary", "novelty_claim"],
      "properties": {
        "summary": { "type": "string", "minLength": 10 },
        "novelty_claim": { "type": "string", "minLength": 10 },
        "non_goals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["idea", "architecture", "source_code", "tests", "self_critique", "risk_assessment", "scorecard", "report"],
      "properties": {
        "idea": { "type": "string" },
        "architecture": { "type": "string" },
        "diagrams": { "type": "array", "items": { "type": "string" } },
        "source_code": { "type": "string" },
        "tests": { "type": "string" },
        "evidence": { "type": "string" },
        "self_critique": { "type": "string" },
        "risk_assessment": { "type": "string" },
        "scorecard": { "type": "string" },
        "report": { "type": "string" },
        "challenge_doc": { "type": "string" },
        "agent_signature": { "type": "string" }
      }
    },
    "lineage": {
      "type": "object",
      "properties": {
        "replaces": { "type": ["string", "null"] },
        "superseded_by": { "type": ["string", "null"] },
        "derived_from": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": true
}
